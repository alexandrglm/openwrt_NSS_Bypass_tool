# Maintainer: Alexander Gomez <alexandrglm@proton.me>
pkgname=nss-switch
pkgver=1.0.0
pkgrel=1
pkgdesc="Qualcomm NSS Bypass tool, Hybrid C"
url="https://github.com/alexandrglm/openwrt_NSS_Bypass_tool"
arch="noarch"
# depends="conntrack"
license="GPL-2.0-only"
options="!check !strip !scanelf !scandeps !archcheck !install"
source="source.tar.gz"
install="nss-switch.pre-install nss-switch.post-install nss-switch.pre-deinstall nss-switch.post-deinstall"

prepare() {
    mkdir -p "$builddir"
    cp -r "$startdir/source"/* "$builddir/" 2>/dev/null || true

    if [ -f "$startdir/nss-switch.pre-install" ]; then
        cp "$startdir/nss-switch.pre-install" "$builddir/"
    fi
    if [ -f "$startdir/nss-switch.post-install" ]; then
        cp "$startdir/nss-switch.post-install" "$builddir/"
    fi
    if [ -f "$startdir/nss-switch.pre-deinstall" ]; then
        cp "$startdir/nss-switch.pre-deinstall" "$builddir/"
    fi
    if [ -f "$startdir/nss-switch.post-deinstall" ]; then
        cp "$startdir/nss-switch.post-deinstall" "$builddir/"
    fi
}

package() {
    cd "$srcdir"
    mkdir -p "$pkgdir/usr/lib/nss-switch/bin"
    mkdir -p "$pkgdir/usr/lib/nss-switch/lib"
    mkdir -p "$pkgdir/etc/config"
    mkdir -p "$pkgdir/etc/firewall.d"
    mkdir -p "$pkgdir/etc/nss-switch"
    mkdir -p "$pkgdir/usr/bin"
    install -Dm755 source/usr/lib/nss-switch/nss-switch.sh "$pkgdir/usr/lib/nss-switch/nss-switch.sh"
    install -Dm755 source/usr/lib/nss-switch/bin/nss-ct-dump "$pkgdir/usr/lib/nss-switch/bin/nss-ct-dump"
    install -Dm755 source/usr/lib/nss-switch/lib/chandler.sh "$pkgdir/usr/lib/nss-switch/lib/chandler.sh"
    install -Dm755 source/usr/lib/nss-switch/lib/conntrack.sh "$pkgdir/usr/lib/nss-switch/lib/conntrack.sh"
    install -Dm755 source/usr/lib/nss-switch/lib/debug.sh "$pkgdir/usr/lib/nss-switch/lib/debug.sh"
    install -Dm755 source/usr/lib/nss-switch/lib/detect.sh "$pkgdir/usr/lib/nss-switch/lib/detect.sh"
    install -Dm755 source/usr/lib/nss-switch/lib/ecm.sh "$pkgdir/usr/lib/nss-switch/lib/ecm.sh"
    install -Dm755 source/usr/lib/nss-switch/lib/nft.sh "$pkgdir/usr/lib/nss-switch/lib/nft.sh"
    install -Dm755 source/usr/lib/nss-switch/lib/rules.sh "$pkgdir/usr/lib/nss-switch/lib/rules.sh"
    install -Dm755 source/usr/lib/nss-switch/lib/ui.sh "$pkgdir/usr/lib/nss-switch/lib/ui.sh"
    install -Dm644 source/etc/config/nss-switch "$pkgdir/etc/config/nss-switch"
    install -Dm755 source/etc/firewall.d/nss-bypass-rules "$pkgdir/etc/firewall.d/nss-bypass-rules"
    if [ -f source/etc/nss-switch/rules.conf ]; then
        install -Dm644 source/etc/nss-switch/rules.conf "$pkgdir/etc/nss-switch/rules.conf"
    else
        echo "# NSS-Switch rules: id|proto|src_ip|dst_ip|src_port|dst_port|iface|persist|comment" > "$pkgdir/etc/nss-switch/rules.conf"
    fi
    install -Dm755 source/usr/lib/nss-switch/lifecycle/nss-switch_preinst.source "$pkgdir/usr/lib/nss-switch/lifecycle/nss-switch_preinst.source"
    install -Dm755 source/usr/lib/nss-switch/lifecycle/nss-switch_postinst.source "$pkgdir/usr/lib/nss-switch/lifecycle/nss-switch_postinst.source"
    install -Dm755 source/usr/lib/nss-switch/lifecycle/nss-switch_prerm.source "$pkgdir/usr/lib/nss-switch/lifecycle/nss-switch_prerm.source"
    # install -Dm755 source/usr/lib/nss-switch/lifecycle/nss-switch.post-deinstall "$pkgdir/usr/lib/nss-switch/lifecycle/nss-switch.post-deinstall"
    ln -sf /usr/lib/nss-switch/nss-switch.sh "$pkgdir/usr/bin/nss-switch"
}

